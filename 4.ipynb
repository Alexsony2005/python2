   "source": [
    "n = int(input(\"Enter number of terms: \"))\n",
    "\n",
    "a, b = 0, 1\n",
    "print(\"\\nEntered Value:\", n)\n",
    "print(\"Fibonacci Series:\")\n",
    "\n",
    "print(a, b, end=\" \")\n",
    "for i in range(2, n):\n",
    "    c = a + b\n",
    "    print(c, end=\" \")\n",
    "    a = b\n",
    "    b = c\n"
   ]
  }
