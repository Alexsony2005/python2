   "source": [
    "text = input(\"Enter message: \")\n",
    "shift = int(input(\"Enter shift: \"))\n",
    "result = \"\"\n",
    "\n",
    "for char in text:\n",
    "    if char.isalpha():\n",
    "        result += chr((ord(char) + shift - 97) % 26 + 97)\n",
    "    else:\n",
    "        result += char\n",
    "\n",
    "print(\"Entered Message:\", text)\n",
    "print(\"Encrypted Message:\", result)\n"
   ]
  }
 ],
